{
  "identity": {
    "name": "CarryOn™",
    "tagline": "Every American Family. Ready.",
    "archetype": "Jewel & Luxury (Legacy Edition)",
    "tone": "Secure, Premium, Trustworthy, Timeless"
  },
  "typography": {
    "headings": {
      "family": "'Outfit', system-ui, sans-serif",
      "weights": ["500", "600", "700"]
    },
    "body": {
      "family": "'DM Sans', system-ui, sans-serif",
      "weights": ["400", "500"]
    },
    "serif": {
      "family": "'Cormorant Garamond', Georgia, serif",
      "usage": "Special accent text"
    }
  },
  "colors": {
    "dark_theme": {
      "bg": "#08090F",
      "bg2": "#0D1018",
      "bg3": "#12151F",
      "surface": "rgba(255,255,255,0.035)",
      "border": "rgba(255,255,255,0.07)",
      "border_highlight": "rgba(255,255,255,0.12)",
      "text": {
        "primary": "#F1F3F8",
        "secondary": "#D8DEE9",
        "tertiary": "#A0AABF",
        "muted": "#7B879E",
        "subtle": "#525C72"
      },
      "accent": {
        "blue": "#3B7BF7",
        "blue2": "#5B93FA",
        "blue3": "#7AABFD",
        "blue_bg": "rgba(59,123,247,0.12)",
        "green": "#22C993",
        "green2": "#4EDBA8",
        "green_bg": "rgba(34,201,147,0.1)",
        "purple": "#8B5CF6",
        "purple2": "#B794F6",
        "purple_bg": "rgba(139,92,246,0.1)",
        "yellow": "#F5A623",
        "yellow2": "#FFCB57",
        "yellow_bg": "rgba(245,166,35,0.1)",
        "red": "#F05252",
        "red2": "#F98080",
        "red_bg": "rgba(240,82,82,0.1)",
        "gold": "#E0AD2B",
        "gold2": "#F0C95C",
        "gold_bg": "rgba(217,119,6,0.12)"
      }
    },
    "light_theme": {
      "bg": "#F8FAFC",
      "bg2": "#F1F5F9",
      "bg3": "#E2E8F0",
      "surface": "rgba(0,0,0,0.02)",
      "border": "rgba(0,0,0,0.08)",
      "text": {
        "primary": "#0F172A",
        "secondary": "#475569",
        "muted": "#94A3B8"
      }
    }
  },
  "components": {
    "sidebar": {
      "width": "260px",
      "collapsed_width": "72px",
      "background": "linear-gradient(180deg, rgba(13,16,24,0.98) 0%, rgba(8,9,15,0.99) 100%)",
      "border": "1px solid rgba(255,255,255,0.05)"
    },
    "cards": {
      "background": "rgba(13,16,24,0.6)",
      "backdrop_filter": "blur(12px)",
      "border": "1px solid rgba(255,255,255,0.07)",
      "border_radius": "16px",
      "hover_border": "rgba(255,255,255,0.15)"
    },
    "buttons": {
      "primary": {
        "background": "linear-gradient(135deg, #3B7BF7 0%, #5B93FA 100%)",
        "text": "#FFFFFF",
        "border_radius": "10px"
      },
      "gold": {
        "background": "linear-gradient(135deg, #E0AD2B 0%, #F0C95C 100%)",
        "text": "#08090F",
        "border_radius": "9999px"
      },
      "secondary": {
        "background": "rgba(255,255,255,0.05)",
        "border": "1px solid rgba(255,255,255,0.07)",
        "text": "#F1F3F8"
      }
    },
    "inputs": {
      "background": "rgba(255,255,255,0.03)",
      "border": "1px solid rgba(255,255,255,0.07)",
      "border_radius": "11px",
      "focus_border": "#3B7BF7"
    },
    "navigation_item": {
      "padding": "12px 16px",
      "border_radius": "10px",
      "active_bg": "linear-gradient(90deg, rgba(224,173,43,0.12) 0%, rgba(224,173,43,0.04) 100%)",
      "active_indicator": "3px solid #E0AD2B"
    }
  },
  "layout": {
    "page": {
      "padding": "36px 42px",
      "max_width": "1200px"
    },
    "grid": {
      "type": "CSS Grid",
      "gap": "24px"
    },
    "breakpoints": {
      "mobile": "640px",
      "tablet": "768px",
      "desktop": "1024px"
    }
  },
  "navigation_structure": {
    "sections": [
      {
        "title": "MY LEGACY",
        "items": [
          {"id": "dashboard", "label": "Dashboard", "icon": "LayoutDashboard"},
          {"id": "vault", "label": "Secure Document Vault", "icon": "FolderLock"},
          {"id": "guardian", "label": "Estate Guardian", "icon": "Sparkles"},
          {"id": "checklist", "label": "Immediate Action Checklist", "icon": "CheckSquare"},
          {"id": "messages", "label": "Milestone Messages", "icon": "MessageSquare"},
          {"id": "beneficiaries", "label": "Beneficiaries", "icon": "Users"},
          {"id": "trustee", "label": "Trustee Services", "icon": "Shield"}
        ]
      },
      {
        "title": "ACCOUNT",
        "items": [
          {"id": "settings", "label": "Settings", "icon": "Settings"}
        ]
      }
    ]
  }
}
